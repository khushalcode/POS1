# npm/electron mirror configuration
# These mirrors prevent "Failed to archive download files" errors when
# electron-builder tries to download winCodeSign/nsis/electron binaries
# from GitHub (which is slow or blocked in many regions).

# Electron binary mirror (used by electron-builder and electron npm package)
ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/
ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/
ELECTRON_CUSTOM_DIR={{ version }}

# Other binary mirrors (speeds up npm install)
SASS_BINARY_SITE=https://npmmirror.com/mirrors/node-sass
NODE_MIRROR=https://npmmirror.com/mirrors/node/

# Use a faster npm registry (optional — uncomment if npm install is slow)
# registry=https://registry.npmmirror.com/
